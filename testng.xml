<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="RestAssured-TestNG API Test Suite" verbose="1" thread-count="1">

    <listeners>
        <listener class-name="com.expandtesting.listeners.ExtentReportListener"/>
    </listeners>

    <!-- ======================== SMOKE SUITE ======================== -->
    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
                <exclude name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="com.expandtesting.tests.health.HealthCheckTest"/>
            <class name="com.expandtesting.tests.users.RegisterUserTest"/>
            <class name="com.expandtesting.tests.users.LoginUserTest"/>
            <class name="com.expandtesting.tests.users.UserProfileTest"/>
            <class name="com.expandtesting.tests.notes.CreateNoteTest"/>
            <class name="com.expandtesting.tests.notes.GetNotesTest"/>
        </classes>
    </test>

    <!-- ======================== REGRESSION SUITE ======================== -->
    <test name="Regression Tests">
        <groups>
            <run>
                <include name="regression"/>
                <exclude name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.expandtesting.tests.users.RegisterUserTest"/>
            <class name="com.expandtesting.tests.users.LoginUserTest"/>
            <class name="com.expandtesting.tests.users.UserProfileTest"/>
            <class name="com.expandtesting.tests.users.ChangePasswordTest"/>
            <class name="com.expandtesting.tests.notes.CreateNoteTest"/>
            <class name="com.expandtesting.tests.notes.GetNotesTest"/>
            <class name="com.expandtesting.tests.notes.UpdateNoteTest"/>
            <class name="com.expandtesting.tests.notes.DeleteNoteTest"/>
        </classes>
    </test>

</suite>

